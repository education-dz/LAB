rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBALS & HELPERS
    // -------------------------------------------------------------------------

    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function isOwner(userId) { 
      return isSignedIn() && request.auth.uid == userId; 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.size() > 0;
    }

    // -------------------------------------------------------------------------
    // ENTITY VALIDATORS (PILLAR 2)
    // -------------------------------------------------------------------------

    function isValidChemical(data) {
      return data.keys().hasAll(['nameAr', 'quantity', 'unit']) &&
             data.nameAr is string && data.nameAr.size() > 0 &&
             data.quantity is number;
    }

    function isValidEquipment(data) {
      return data.keys().hasAll(['name', 'type', 'status']) &&
             data.name is string &&
             data.type in ['glassware', 'tech', 'other'] &&
             data.status in ['functional', 'maintenance', 'broken'];
    }

    // -------------------------------------------------------------------------
    // SETTINGS / CONFIG
    // -------------------------------------------------------------------------
    match /settings/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidId(userId);
    }

    // -------------------------------------------------------------------------
    // USER SANDBOXES (PILLAR 1 & 6)
    // -------------------------------------------------------------------------

    match /users/{userId} {
      // Allow the user to document their own profile/settings
      allow list: if isOwner(userId);
      allow get, write: if isOwner(userId) && isValidId(userId);
      
      // All user-owned collections follow the same list/get split (PILLAR 3)
      match /{collection}/{docId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId) && isValidId(docId);
        
        // Base write for non-validated collections
        allow write: if isOwner(userId) && isValidId(docId);
        
        // Hardened writes for specific collections (PILLAR 4)
        allow create, update: if isOwner(userId) && isValidId(docId) && (
          (collection == 'chemicals' && isValidChemical(incoming())) ||
          (collection == 'equipment' && isValidEquipment(incoming())) ||
          (collection != 'chemicals' && collection != 'equipment')
        );
      }
      
      // Support for deeper paths (e.g. notifications)
      match /{collection}/{docId}/{subCollection}/{subId} {
        allow list: if isOwner(userId);
        allow get, write: if isOwner(userId) && isValidId(subId);
      }
    }

    // Connection test path
    match /_connection_test_/{docId} {
      allow read, write: if isSignedIn();
    }

    // Default Deny (PILLAR 0)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
