rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------------------------
    // GLOBAL HELPERS
    // ------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMasterUser() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ------------------------------------------------------------
    // DEFAULT DENY
    // ------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isMasterUser();
    }

    // ------------------------------------------------------------
    // CONNECTION TEST PATH
    // ------------------------------------------------------------
    match /_connection_test_/{docId} {
      allow read, write: if isSignedIn();
    }

    // ------------------------------------------------------------
    // USER DATA (SOPHISTICATED SCOPING)
    // ------------------------------------------------------------
    match /users/{userId} {
      // Allow the user to read/write their own root document
      allow get, write: if isOwner(userId);
      
      // Allow the user to read/write any document in any of their own subcollections
      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // ------------------------------------------------------------
    // SETTINGS DATA
    // ------------------------------------------------------------
    match /settings/{userId} {
      // Allow the user to read/write their own settings document
      allow get, write: if isOwner(userId);
    }
  }
}
