rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------------------------
    // GLOBAL HELPERS
    // ------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMasterUser() {
      return isSignedIn() && (
        request.auth.uid == 'UMDdyJMUXHVilG0ihIjTxULQ0yd2' || 
        request.auth.token.email == 'faycalassoul@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ------------------------------------------------------------
    // DEFAULT DENY
    // ------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isMasterUser();
    }

    // ------------------------------------------------------------
    // CONNECTION TEST PATH
    // ------------------------------------------------------------
    match /_connection_test_/{docId} {
      allow read, write: if isSignedIn();
    }

    // ------------------------------------------------------------
    // USER DATA (SOPHISTICATED SCOPING)
    // ------------------------------------------------------------
    match /users/{userId} {
      allow get, write: if isOwner(userId);
      
      // Personal settings/profile data
      match /settings/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      // Core Laboratory Entities (User-Scoped)
      match /chemicals/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /equipment/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /teachers/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /incident_logs/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /reports/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /backups/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /loans/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /activity_preparations/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /scrapping_records/{docId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
