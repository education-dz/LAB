rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email (optional), phoneNumber (optional), role, displayName
    // Required: uid, role
    // Collection: chemicals
    // Fields: name, formula, quantity, unit, location, expiryDate, hazardClass
    //
    // Collection: equipment
    // Fields: name, category, status, quantity, location, lastMaintenance
    //
    // Collection: teachers
    // Fields: name, subject, email, phone, classes
    //
    // Collection: safety_equipment
    // Fields: name, status, lastCheck, location, type
    //
    // Collection: incident_logs
    // Fields: title, date, severity, description, reporter
    //
    // Collection: reports
    // Fields: title, generatedAt, stats, type
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "faycalassoul@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function isValidString(field, min, max) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= min && 
             request.resource.data[field].size() <= max;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      match /{allPaths=**} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      }
    }

    match /settings/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /_connection_test_/{docId} {
      allow read: if isAuthenticated();
    }
  }
}
